#
# ------------------------------------------------------------------------------
#  目标平台与固件设置
#      定义编译目标架构、设备类型及根文件系统镜像参数。
# ------------------------------------------------------------------------------
#
# 目标架构：x86（32/64 位 x86 平台大类）
CONFIG_TARGET_x86=y
# 目标子架构：x86_64（64 位）
CONFIG_TARGET_x86_64=y
# 设备类型：通用 x86_64 设备（适用于常见虚拟机与物理机）
CONFIG_TARGET_x86_64_DEVICE_generic=y
# 不额外生成 ext4 格式根文件系统镜像（默认输出 squashfs 镜像）
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
# 根分区大小：1024 MB，预留足够空间安装插件与存放数据
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

#
# ------------------------------------------------------------------------------
#  代理软件与核心（科学上网）
#      包含 LuCI 管理界面、代理核心引擎及透明代理所需内核模块。
# ------------------------------------------------------------------------------
#
# --- PassWall（主力代理）---
# PassWall：综合代理管理界面（主力）
CONFIG_PACKAGE_luci-app-passwall=y
# PassWall 简体中文语言包
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# --- MoMo ---
# MoMo 图形管理界面
CONFIG_PACKAGE_luci-app-momo=y
# MoMo 简体中文语言包
CONFIG_PACKAGE_luci-i18n-momo-zh-cn=y
# momo 服务主程序
CONFIG_PACKAGE_momo=y

# --- Nikki ---
# Nikki：mihomo 内核的另一套管理界面
CONFIG_PACKAGE_luci-app-nikki=y
# Nikki 简体中文语言包
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y
# nikki 服务主程序
CONFIG_PACKAGE_nikki=y

# --- 代理核心与引擎（共享）---
# sing-box：通用代理平台核心
CONFIG_PACKAGE_sing-box=y
# Xray：v2ray/xray 代理核心
CONFIG_PACKAGE_xray-core=y
# mihomo（Clash.Meta）代理核心（momo / nikki 共用）
CONFIG_PACKAGE_mihomo-meta=y
# Shadowsocks-Rust 客户端
CONFIG_PACKAGE_shadowsocks-rust-sslocal=y
# Shadowsocks-Rust 服务端
CONFIG_PACKAGE_shadowsocks-rust-ssserver=y
# microsocks：轻量级 SOCKS5 代理服务器
CONFIG_PACKAGE_microsocks=y
# dns2socks：将 DNS 查询经 SOCKS5 转发
CONFIG_PACKAGE_dns2socks=y
# ipt2socks：将 iptables 重定向流量转为 SOCKS5
CONFIG_PACKAGE_ipt2socks=y
# v2ray-plugin：Shadowsocks 的 v2ray 传输插件
CONFIG_PACKAGE_v2ray-plugin=y
# simple-obfs：混淆插件客户端
CONFIG_PACKAGE_simple-obfs-client=y
# HAProxy：PassWall 节点负载均衡所需
CONFIG_PACKAGE_haproxy=y
# geoview：查看/解析 GeoIP、GeoSite 规则数据
CONFIG_PACKAGE_geoview=y
# TUN 虚拟网卡内核模块（TUN 模式代理必需）
CONFIG_PACKAGE_kmod-tun=y

# --- 透明代理内核模块（TPROXY）---
# iptables 版 socket 匹配模块
CONFIG_PACKAGE_kmod-nf-socket=y
# iptables 版 TPROXY 透明代理模块
CONFIG_PACKAGE_kmod-nf-tproxy=y
# nftables 版 socket 匹配模块
CONFIG_PACKAGE_kmod-nft-socket=y
# nftables 版 TPROXY 透明代理模块
CONFIG_PACKAGE_kmod-nft-tproxy=y

#
# ------------------------------------------------------------------------------
#  DNS 与广告过滤
#      DNS 分流、去广告与 DNS-over-HTTPS/TLS 服务。
# ------------------------------------------------------------------------------
#
# AdGuardHome：DNS 层广告过滤与 DoH/DoT 服务
CONFIG_PACKAGE_adguardhome=y
# AdGuardHome 的 LuCI 管理界面
CONFIG_PACKAGE_luci-app-adguardhome=y
# ChinaDNS-NG：国内外域名 DNS 分流，防污染
CONFIG_PACKAGE_chinadns-ng=y

#
# ------------------------------------------------------------------------------
#  应用识别与过滤（AppFilter）
#      基于 DPI 的应用层流量识别与访问控制。
# ------------------------------------------------------------------------------
#
# AppFilter 应用过滤主程序
CONFIG_PACKAGE_appfilter=y
# AppFilter 的 LuCI 管理界面
CONFIG_PACKAGE_luci-app-appfilter=y
# AppFilter 简体中文语言包
CONFIG_PACKAGE_luci-i18n-appfilter-zh-cn=y
# OAF 内核模块（AppFilter 流量识别底层）
CONFIG_PACKAGE_kmod-oaf=y

#
# ------------------------------------------------------------------------------
#  QoS 智能队列管理（SQM）
#      降低网络延迟（Bufferbloat）、公平分配带宽。
# ------------------------------------------------------------------------------
#
# SQM 脚本主程序
CONFIG_PACKAGE_sqm-scripts=y
# SQM 的 LuCI 管理界面
CONFIG_PACKAGE_luci-app-sqm=y
# SQM 简体中文语言包
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
# CAKE 队列调度算法内核模块（SQM 推荐算法）
CONFIG_PACKAGE_kmod-sched-cake=y
# TC 队列调度核心内核模块
CONFIG_PACKAGE_kmod-sched-core=y
# IFB 虚拟网卡模块（用于下行整形）
CONFIG_PACKAGE_kmod-ifb=y
# tc 精简版流量控制工具
CONFIG_PACKAGE_tc-tiny=y

#
# ------------------------------------------------------------------------------
#  系统监控与统计
#      collectd 采集 + rrdtool 绘图 + LuCI 统计界面（以模块 m 方式编译）。
# ------------------------------------------------------------------------------
#
# LuCI 统计信息展示界面
CONFIG_PACKAGE_luci-app-statistics=m
# 统计信息 简体中文语言包（随统计模块以 m 方式编译）
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=m
# collectd 数据采集守护进程
CONFIG_PACKAGE_collectd=m
# collectd 模块：CPU 使用率
CONFIG_PACKAGE_collectd-mod-cpu=m
# collectd 模块：网络接口流量
CONFIG_PACKAGE_collectd-mod-interface=m
# collectd 模块：无线信息（iwinfo）
CONFIG_PACKAGE_collectd-mod-iwinfo=m
# collectd 模块：系统负载
CONFIG_PACKAGE_collectd-mod-load=m
# collectd 模块：内存使用
CONFIG_PACKAGE_collectd-mod-memory=m
# collectd 模块：网络数据收发（跨主机）
CONFIG_PACKAGE_collectd-mod-network=m
# collectd 模块：写入 RRDtool 数据库
CONFIG_PACKAGE_collectd-mod-rrdtool=m
# RRDtool：时序数据库与绘图工具
CONFIG_PACKAGE_rrdtool1=m
# RRDtool 运行库
CONFIG_PACKAGE_librrd1=m

#
# ------------------------------------------------------------------------------
#  防火墙与 Netfilter 内核模块
#      iptables(nft) 兼容层及连接跟踪、诊断等底层内核模块。
# ------------------------------------------------------------------------------
#
# iptables 的 nftables 后端实现
CONFIG_PACKAGE_iptables-nft=y
# xtables 的 nftables 后端实现
CONFIG_PACKAGE_xtables-nft=y
# iptables 扩展：IP 选项匹配
CONFIG_PACKAGE_iptables-mod-ipopt=y
# 内核模块：连接跟踪（conntrack）
CONFIG_PACKAGE_kmod-ipt-conntrack=y
# 内核模块：iptables 核心
CONFIG_PACKAGE_kmod-ipt-core=y
# 内核模块：IP 选项匹配
CONFIG_PACKAGE_kmod-ipt-ipopt=y
# 内核模块：nftables 与 iptables 桥接
CONFIG_PACKAGE_kmod-nf-ipt=y
# 内核模块：nftables 兼容 iptables 扩展
CONFIG_PACKAGE_kmod-nft-compat=y
# 内核模块：inet 套接字诊断（ss 命令等使用）
CONFIG_PACKAGE_kmod-inet-diag=y
# 内核模块：netlink 套接字诊断
CONFIG_PACKAGE_kmod-netlink-diag=y
# 内核模块：dummy 虚拟网卡
CONFIG_PACKAGE_kmod-dummy=y

#
# ------------------------------------------------------------------------------
#  LuCI 界面、主题与运行时
#      Web 管理界面主题及其依赖库、兼容层。
# ------------------------------------------------------------------------------
#
# Argon 主题（美观的 LuCI 主题）
CONFIG_PACKAGE_luci-theme-argon=y
# Argon 主题设置界面
CONFIG_PACKAGE_luci-app-argon-config=y
# Argon 主题设置 简体中文语言包
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
# LuCI 兼容层（老式插件依赖）
CONFIG_PACKAGE_luci-compat=y
# LuCI 基础库
CONFIG_PACKAGE_luci-lib-base=y
# LuCI IP 处理库
CONFIG_PACKAGE_luci-lib-ip=y
# LuCI JSON 解析库
CONFIG_PACKAGE_luci-lib-jsonc=y
# LuCI nixio 系统调用库
CONFIG_PACKAGE_luci-lib-nixio=y
# LuCI Lua 运行时
CONFIG_PACKAGE_luci-lua-runtime=y

#
# ------------------------------------------------------------------------------
#  Lua 运行环境
#      LuCI 及部分插件依赖的 Lua 解释器与绑定库。
# ------------------------------------------------------------------------------
#
# Lua 解释器
CONFIG_PACKAGE_lua=y
# Lua 运行库
CONFIG_PACKAGE_liblua=y
# Lua 5.4 运行库
CONFIG_PACKAGE_liblua5.4=y
# ucode 的 Lua 兼容模块
CONFIG_PACKAGE_ucode-mod-lua=y
# lyaml：Lua 的 YAML 解析绑定
CONFIG_PACKAGE_lyaml=y
# lucihttp 的 Lua 绑定
CONFIG_PACKAGE_liblucihttp-lua=y
# ubus 的 Lua 绑定
CONFIG_PACKAGE_libubus-lua=y
# uci 的 Lua 绑定
CONFIG_PACKAGE_libuci-lua=y

#
# ------------------------------------------------------------------------------
#  基础依赖库
#      被上述软件包引用的公共运行库（多为自动依赖）。
# ------------------------------------------------------------------------------
#
# 原子操作库
CONFIG_PACKAGE_libatomic=y
# BPF 库（eBPF 相关功能依赖）
CONFIG_PACKAGE_libbpf=y
# libcurl 运行库
CONFIG_PACKAGE_libcurl=y
# ELF 文件解析库
CONFIG_PACKAGE_libelf=y
# libev 事件循环库
CONFIG_PACKAGE_libev=y
# iptables 文本处理库
CONFIG_PACKAGE_libiptext=y
# iptables 文本处理库（nft 版）
CONFIG_PACKAGE_libiptext-nft=y
# iptables 文本处理库（IPv6）
CONFIG_PACKAGE_libiptext6=y
# libtool 动态加载库
CONFIG_PACKAGE_libltdl=y
# HTTP/2 协议库（curl 依赖）
CONFIG_PACKAGE_libnghttp2=y
# PCRE2 正则表达式库
CONFIG_PACKAGE_libpcre2=y
# readline 行编辑库
CONFIG_PACKAGE_libreadline=y
# xtables 库
CONFIG_PACKAGE_libxtables=y
# YAML 解析库
CONFIG_PACKAGE_libyaml=y

#
# ------------------------------------------------------------------------------
#  系统与网络工具
#      常用命令行工具，方便调试与脚本处理。
# ------------------------------------------------------------------------------
#
# GNU coreutils 核心命令集
CONFIG_PACKAGE_coreutils=y
# coreutils：base64 编解码
CONFIG_PACKAGE_coreutils-base64=y
# coreutils：nohup 后台运行
CONFIG_PACKAGE_coreutils-nohup=y
# coreutils：timeout 超时控制
CONFIG_PACKAGE_coreutils-timeout=y
# curl 命令行下载工具
CONFIG_PACKAGE_curl=y
# ip 命令完整版（iproute2）
CONFIG_PACKAGE_ip-full=y
# resolveip：域名解析工具
CONFIG_PACKAGE_resolveip=y
# tcping：测试 TCP 端口连通性与延迟
CONFIG_PACKAGE_tcping=y
# unzip 解压工具
CONFIG_PACKAGE_unzip=y
# yq：YAML/JSON 命令行处理工具
CONFIG_PACKAGE_yq=y

#
# ------------------------------------------------------------------------------
#  libcurl 功能特性与 PCRE2 编译选项
#      细化 libcurl 支持的协议/认证等特性开关。
# ------------------------------------------------------------------------------
#
# 启用 Cookie 支持
CONFIG_LIBCURL_COOKIES=y
# 启用加密认证
CONFIG_LIBCURL_CRYPTO_AUTH=y
# 启用 file:// 协议
CONFIG_LIBCURL_FILE=y
# 启用 FTP 协议
CONFIG_LIBCURL_FTP=y
# 启用 HTTP 协议
CONFIG_LIBCURL_HTTP=y
# 启用 HTTP/2 协议
CONFIG_LIBCURL_HTTP2=y
# 启用 HTTP 认证
CONFIG_LIBCURL_HTTP_AUTH=y
# 使用 OpenSSL 作为 TLS 后端
CONFIG_LIBCURL_OPENSSL=y
# 启用代理支持
CONFIG_LIBCURL_PROXY=y
# 启用 TFTP 协议
CONFIG_LIBCURL_TFTP=y
# 启用线程化 DNS 解析器
CONFIG_LIBCURL_THREADED_RESOLVER=y
# 启用 TLS-SRP 认证
CONFIG_LIBCURL_TLS_SRP=y
# 启用 Unix 套接字支持
CONFIG_LIBCURL_UNIX_SOCKETS=y
# 启用 zlib 压缩支持
CONFIG_LIBCURL_ZLIB=y
# 启用 PCRE2 JIT 即时编译（提升正则性能）
CONFIG_PCRE2_JIT_ENABLED=y
